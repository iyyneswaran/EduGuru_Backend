generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
}

enum ModuleStatus {
  LOCKED
  UNLOCKED
  COMPLETED
}

enum MaterialType {
  PDF
  VIDEO
  NOTES
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  role           Role     @default(STUDENT)
  xp             Int      @default(0)
  streak         Int      @default(0)
  lastActiveDate DateTime?

  chats              Chat[]
  attempts           PracticeAttempt[]
  classroomsCreated  Classroom[]        @relation("TeacherClassrooms")
  classroomMembers   ClassroomMember[]
  moduleProgress     ModuleProgress[]
  quizAttempts       QuizAttempt[]
  userAchievements   UserAchievement[]

  createdAt DateTime @default(now())
}

model Chat {
  id       String @id @default(uuid())
  userId   String
  message  String
  response String
  user     User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Question {
  id            String            @id @default(uuid())
  topic         String
  difficulty    String
  question      String
  correctAnswer String
  attempts      PracticeAttempt[]

  createdAt DateTime @default(now())
}

model PracticeAttempt {
  id         String  @id @default(uuid())
  userId     String
  questionId String
  answer     String
  correct    Boolean

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Classroom System ────────────────────────────────────────────

model Classroom {
  id          String @id @default(uuid())
  name        String
  subject     String
  description String @default("")
  code        String @unique
  teacherId   String

  teacher   User              @relation("TeacherClassrooms", fields: [teacherId], references: [id])
  members   ClassroomMember[]
  modules   Module[]
  materials StudyMaterial[]
  quizzes   Quiz[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClassroomMember {
  id          String @id @default(uuid())
  userId      String
  classroomId String

  user      User      @relation(fields: [userId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([userId, classroomId])
}

// ─── Learning Modules ────────────────────────────────────────────

model Module {
  id          String @id @default(uuid())
  classroomId String
  title       String
  description String @default("")
  content     String @default("")
  order       Int    @default(0)

  classroom Classroom        @relation(fields: [classroomId], references: [id])
  progress  ModuleProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModuleProgress {
  id       String       @id @default(uuid())
  userId   String
  moduleId String
  status   ModuleStatus @default(LOCKED)

  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
}

// ─── Study Materials ─────────────────────────────────────────────

model StudyMaterial {
  id          String       @id @default(uuid())
  classroomId String
  title       String
  description String       @default("")
  fileUrl     String
  type        MaterialType @default(NOTES)

  classroom Classroom @relation(fields: [classroomId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Quiz System ─────────────────────────────────────────────────

model Quiz {
  id          String @id @default(uuid())
  classroomId String
  title       String
  description String @default("")
  timeLimit   Int    @default(300) // seconds
  points      Int    @default(100)

  classroom Classroom      @relation(fields: [classroomId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  createdAt DateTime @default(now())
}

model QuizQuestion {
  id            String @id @default(uuid())
  quizId        String
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String // "A" | "B" | "C" | "D"

  quiz Quiz @relation(fields: [quizId], references: [id])
}

model QuizAttempt {
  id          String @id @default(uuid())
  quizId      String
  userId      String
  score       Int
  totalPoints Int
  answers     String @default("[]") // JSON string of answers

  quiz Quiz @relation(fields: [quizId], references: [id])
  user User @relation(fields: [userId], references: [id])

  completedAt DateTime @default(now())
}

// ─── Achievements ────────────────────────────────────────────────

model Achievement {
  id          String @id @default(uuid())
  key         String @unique
  title       String
  description String
  icon        String @default("medal")

  users UserAchievement[]
}

model UserAchievement {
  id            String @id @default(uuid())
  userId        String
  achievementId String

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
}